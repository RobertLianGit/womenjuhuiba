/* app.wxss - 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
}

/* 主题色 */
.theme-primary {
  color: #FF4DB8;
}

.bg-primary {
  background-color: #FF4DB8;
  color: #fff;
}

/* 卡片样式 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

/* 按钮样式 */
.btn-primary {
  background-color: #FF4DB8;
  color: #fff;
  border-radius: 40rpx;
  padding: 24rpx 48rpx;
  text-align: center;
  font-weight: 500;
}

.btn-primary:active {
  background-color: #E644A6;
}

.btn-secondary {
  background-color: #f5f5f5;
  color: #333;
  border-radius: 40rpx;
  padding: 24rpx 48rpx;
  text-align: center;
}

/* 状态标签 */
.status-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-collecting {
  background-color: #FFF0F7;
  color: #FF4DB8;
}

.status-voting {
  background-color: #FFF7E6;
  color: #FA8C16;
}

.status-plan {
  background-color: #E6F7FF;
  color: #1890FF;
}

.status-registering {
  background-color: #F6FFED;
  color: #52C41A;
}

.status-started {
  background-color: #F0F5FF;
  color: #2F54EB;
}

.status-settling {
  background-color: #FFF1F0;
  color: #F5222D;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}

/* 表单样式 */
.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  margin-bottom: 16rpx;
  font-weight: 500;
  color: #333;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
  font-size: 28rpx;
}

.form-input:focus {
  border-color: #FF4DB8;
  background-color: #fff;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
  font-size: 28rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #eee;
  margin: 32rpx 0;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

/* 网格布局 */
.grid-2 {
  display: flex;
  flex-wrap: wrap;
  margin: -12rpx;
}

.grid-2 .grid-item {
  width: 50%;
  padding: 12rpx;
  box-sizing: border-box;
}
