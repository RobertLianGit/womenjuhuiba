/* pages/create/create.wxss */
.container {
  padding: 32rpx;
  padding-bottom: 200rpx;
}

.form-section {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 96rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
}

.picker-input {
  height: 96rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: #333;
}

.picker-placeholder {
  color: #999;
}

.code-section {
  background: #fff8e1;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.code-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.code-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.code-label {
  font-size: 26rpx;
  color: #666;
  width: 180rpx;
}

.code-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #07c160;
  letter-spacing: 8rpx;
}

.code-hint {
  font-size: 24rpx;
  color: #f57f17;
  margin-top: 12rpx;
}

.submit-btn {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 48rpx;
  height: 96rpx;
  background: #07c160;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
