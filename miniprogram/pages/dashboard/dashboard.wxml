<!--pages/dashboard/dashboard.wxml-->
<view class="container">
  <!-- 统计 -->
  <view class="stats-section">
    <view class="stat-card">
      <text class="stat-num">{{stats.registered}}</text>
      <text class="stat-label">已报名</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{stats.manual}}</text>
      <text class="stat-label">手动添加</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{stats.total}}</text>
      <text class="stat-label">总人数</text>
    </view>
  </view>

  <!-- 报名参与者 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">报名参与者</text>
    </view>
    
    <view class="participant-list" wx:if="{{registrations.length > 0}}">
      <view class="participant-item" wx:for="{{registrations}}" wx:key="id">
        <image class="participant-avatar" src="{{item.user_avatar || '/assets/default-avatar.png'}}" mode="aspectFill"></image>
        <view class="participant-info">
          <view class="participant-name">{{item.user_name}}</view>
          <view class="participant-meta">
            <text wx:if="{{item.scene_name}}">{{item.scene_name}} | </text>
            <text>{{item.people_count}}人</text>
          </view>
        </view>
      </view>
    </view>
    <view class="empty-state" wx:else>暂无报名</view>
  </view>

  <!-- 手动添加参与者 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">手动添加参与者</text>
      <view class="add-btn" bindtap="showAddForm" wx:if="{{isAdmin}}">+ 添加</view>
    </view>
    
    <view class="participant-list" wx:if="{{manualParticipants.length > 0}}">
      <view class="participant-item" wx:for="{{manualParticipants}}" wx:key="id">
        <view class="participant-info">
          <view class="participant-name">{{item.name}}</view>
          <view class="participant-meta" wx:if="{{item.phone}}">{{item.phone}}</view>
        </view>
        <text class="participant-delete" bindtap="deleteParticipant" data-id="{{item.id}}" wx:if="{{isAdmin}}">删除</text>
      </view>
    </view>
    <view class="empty-state" wx:else>暂无手动添加的参与者</view>
  </view>

  <!-- 管理口令验证 -->
  <view class="admin-section">
    <text class="section-title">管理操作</text>
    <view class="admin-input" wx:if="{{!isAdmin}}">
      <input placeholder="输入管理口令" value="{{passphraseInput}}" bindinput="onPassphraseInput" password/>
      <button class="verify-btn" bindtap="verifyPassphrase">验证</button>
    </view>
    
    <view class="add-form" wx:if="{{isAdmin && showAddParticipant}}">
      <view class="form-row">
        <input class="form-input name" placeholder="姓名" value="{{newName}}" bindinput="onNameInput"/>
        <input class="form-input phone" placeholder="手机号（选填）" value="{{newPhone}}" bindinput="onPhoneInput"/>
      </view>
      <button class="verify-btn" style="width: 100%;" bindtap="addParticipant">确认添加</button>
    </view>
  </view>
</view>
