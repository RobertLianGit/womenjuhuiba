/* pages/dashboard/dashboard.wxss */
.container {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

.stats-section {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #07c160;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
}

.add-btn {
  font-size: 26rpx;
  color: #07c160;
  padding: 8rpx 16rpx;
  background: #e8f5e9;
  border-radius: 8rpx;
}

.participant-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.participant-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.participant-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.participant-info {
  flex: 1;
}

.participant-name {
  font-size: 30rpx;
  font-weight: 500;
}

.participant-meta {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
}

.participant-delete {
  font-size: 26rpx;
  color: #f44336;
  padding: 8rpx 16rpx;
}

.admin-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.admin-input {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.admin-input input {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.verify-btn {
  width: 140rpx;
  height: 80rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-form {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.form-row {
  display: flex;
  gap: 16rpx;
}

.form-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.form-input.name {
  flex: 2;
}

.form-input.phone {
  flex: 3;
}

.empty-state {
  text-align: center;
  padding: 48rpx;
  color: #999;
  font-size: 28rpx;
}
