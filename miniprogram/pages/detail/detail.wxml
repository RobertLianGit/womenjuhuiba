<!--pages/detail/detail.wxml-->
<view class="container">
  <!-- 活动头部 -->
  <view class="activity-header">
    <text class="activity-name">{{activity.name}}</text>
    <view class="activity-meta">
      <view class="meta-item">
        <image class="meta-icon" src="/assets/icon-user.png" mode="aspectFit"></image>
        <text>{{activity.creator_name}}</text>
      </view>
      <view class="meta-item" wx:if="{{activity.activity_time}}">
        <image class="meta-icon" src="/assets/icon-calendar.png" mode="aspectFit"></image>
        <text>{{activity.activity_time}}</text>
      </view>
      <view class="meta-item" wx:if="{{activity.location}}">
        <image class="meta-icon" src="/assets/icon-location.png" mode="aspectFit"></image>
        <text>{{activity.location}}</text>
      </view>
    </view>
    <view class="activity-desc" wx:if="{{activity.description}}">{{activity.description}}</view>
  </view>

  <!-- 状态区域 -->
  <view class="status-section">
    <view class="status-header">
      <text class="status-title">当前进度</text>
      <view class="status-badge status-{{activity.status}}">{{activity.statusText}}</view>
    </view>
    
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-num">{{stats.intentionCount}}</text>
        <text class="stat-label">已表态</text>
      </view>
      <view class="stat-card">
        <text class="stat-num">{{stats.voteCount}}</text>
        <text class="stat-label">已投票</text>
      </view>
      <view class="stat-card">
        <text class="stat-num">{{stats.registerCount}}</text>
        <text class="stat-label">已报名</text>
      </view>
    </view>
  </view>

  <!-- 参与操作 -->
  <view class="actions-section">
    <text class="actions-title">参与活动</text>
    
    <view class="action-btn" bindtap="goToIntention" wx:if="{{activity.status === 'collecting'}}">
      <image class="action-icon" src="/assets/icon-intention.png" mode="aspectFit"></image>
      <text class="action-text">填写意愿</text>
      <image class="action-arrow" src="/assets/icon-arrow.png" mode="aspectFit"></image>
    </view>

    <view class="action-btn" bindtap="goToVote" wx:if="{{activity.status === 'voting'}}">
      <image class="action-icon" src="/assets/icon-vote.png" mode="aspectFit"></image>
      <text class="action-text">参与投票</text>
      <image class="action-arrow" src="/assets/icon-arrow.png" mode="aspectFit"></image>
    </view>

    <view class="action-btn" bindtap="goToPlan" wx:if="{{activity.status === 'plan'}}">
      <image class="action-icon" src="/assets/icon-plan.png" mode="aspectFit"></image>
      <text class="action-text">查看方案</text>
      <image class="action-arrow" src="/assets/icon-arrow.png" mode="aspectFit"></image>
    </view>

    <view class="action-btn" bindtap="goToRegister" wx:if="{{activity.status === 'registering'}}">
      <image class="action-icon" src="/assets/icon-register.png" mode="aspectFit"></image>
      <text class="action-text">立即报名</text>
      <image class="action-arrow" src="/assets/icon-arrow.png" mode="aspectFit"></image>
    </view>

    <view class="action-btn" bindtap="goToDashboard" wx:if="{{activity.status === 'started'}}">
      <image class="action-icon" src="/assets/icon-dashboard.png" mode="aspectFit"></image>
      <text class="action-text">查看参与者</text>
      <image class="action-arrow" src="/assets/icon-arrow.png" mode="aspectFit"></image>
    </view>

    <view class="action-btn" bindtap="goToSettle" wx:if="{{activity.status === 'settling' || activity.status === 'settled'}}">
      <image class="action-icon" src="/assets/icon-settle.png" mode="aspectFit"></image>
      <text class="action-text">查看结算</text>
      <image class="action-arrow" src="/assets/icon-arrow.png" mode="aspectFit"></image>
    </view>
  </view>

  <!-- 管理操作 -->
  <view class="admin-section">
    <text class="admin-title">管理操作</text>
    <view class="admin-input">
      <input placeholder="输入管理口令" value="{{passphraseInput}}" bindinput="onPassphraseInput" password/>
      <button class="admin-btn" bindtap="verifyPassphrase">验证</button>
    </view>
    
    <view class="admin-actions" wx:if="{{isAdmin}}">
      <button class="admin-action-btn" bindtap="changeStatus">进入下一阶段</button>
      <button class="admin-action-btn" bindtap="goToPlan">设置方案</button>
      <button class="admin-action-btn" bindtap="goToDashboard">管理参与者</button>
      <button class="admin-action-btn" bindtap="goToSettle">记账结算</button>
    </view>
  </view>

  <button class="share-btn" open-type="share">分享活动</button>
</view>
