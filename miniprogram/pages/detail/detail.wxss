/* pages/detail/detail.wxss */
.container {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

.activity-header {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.activity-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.activity-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.meta-icon {
  width: 32rpx;
  height: 32rpx;
}

.activity-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #eee;
}

.status-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.status-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.status-title {
  font-size: 32rpx;
  font-weight: 600;
}

.status-badge {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #07c160;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.actions-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.actions-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  width: 100%;
  height: 96rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}

.action-btn:last-child {
  margin-bottom: 0;
}

.action-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.action-text {
  font-size: 30rpx;
  color: #333;
  flex: 1;
}

.action-arrow {
  width: 32rpx;
  height: 32rpx;
}

.admin-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.admin-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.admin-input {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.admin-input input {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.admin-btn {
  width: 160rpx;
  height: 80rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

.admin-action-btn {
  height: 80rpx;
  background: #e3f2fd;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1976d2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-btn {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 48rpx;
  height: 96rpx;
  background: #07c160;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
