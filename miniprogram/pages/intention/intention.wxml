<!--pages/intention/intention.wxml-->
<view class="container">
  <!-- 时间选择 -->
  <view class="section">
    <text class="section-title">你方便的时间</text>
    <view class="time-section">
      <picker mode="date" value="{{availableDate}}" bindchange="onDateChange">
        <view class="time-picker">{{availableDate || '选择日期'}}</view>
      </picker>
      <picker mode="time" value="{{availableTime}}" bindchange="onTimeChange">
        <view class="time-picker">{{availableTime || '选择时间'}}</view>
      </picker>
    </view>
  </view>

  <!-- 地点偏好 -->
  <view class="section">
    <text class="section-title">你想去的地方</text>
    <view class="option-list">
      <view class="option-item {{item.active ? 'active' : ''}}" 
            wx:for="{{locationOptions}}" 
            wx:key="value"
            bindtap="toggleLocation"
            data-index="{{index}}">
        {{item.value}}
      </view>
    </view>
    <view class="custom-input">
      <input placeholder="其他地点..." value="{{customLocation}}" bindinput="onCustomLocationInput"/>
      <button class="add-btn" bindtap="addCustomLocation">添加</button>
    </view>
  </view>

  <!-- 活动内容 -->
  <view class="section">
    <text class="section-title">你想做什么</text>
    <view class="option-list">
      <view class="option-item {{item.active ? 'active' : ''}}" 
            wx:for="{{activityOptions}}" 
            wx:key="value"
            bindtap="toggleActivity"
            data-index="{{index}}">
        {{item.value}}
      </view>
    </view>
    <view class="custom-input">
      <input placeholder="其他活动..." value="{{customActivity}}" bindinput="onCustomActivityInput"/>
      <button class="add-btn" bindtap="addCustomActivity">添加</button>
    </view>
  </view>

  <!-- 备注 -->
  <view class="section">
    <text class="section-title">其他说明</text>
    <textarea class="notes-input" placeholder="有什么想说的..." value="{{notes}}" bindinput="onNotesInput"/>
  </view>

  <!-- 已表态列表 -->
  <view class="summary-section" wx:if="{{intentions.length > 0}}">
    <text class="summary-title">已表态 ({{intentions.length}}人)</text>
    <view class="summary-list">
      <view class="summary-item" wx:for="{{intentions}}" wx:key="id">
        <text class="summary-name">{{item.user_name}}</text>
        <text class="summary-content">{{item.available_time || '时间待定'}} | {{item.preferred_locations || '地点待定'}}</text>
      </view>
    </view>
  </view>

  <button class="submit-btn" bindtap="submit">提交意愿</button>
</view>
