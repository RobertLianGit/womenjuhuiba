/* pages/plan/plan.wxss */
.container {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

.voting-result {
  background: #e3f2fd;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.result-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 26rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
}

.add-btn {
  font-size: 26rpx;
  color: #07c160;
  padding: 8rpx 16rpx;
  background: #e8f5e9;
  border-radius: 8rpx;
}

.scene-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.scene-item {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
}

.scene-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.scene-name {
  font-size: 30rpx;
  font-weight: 500;
}

.scene-actions {
  display: flex;
  gap: 16rpx;
}

.action-text {
  font-size: 26rpx;
  color: #07c160;
}

.action-text.delete {
  color: #f44336;
}

.scene-info {
  font-size: 26rpx;
  color: #666;
}

.form-input {
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.form-textarea {
  min-height: 160rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.prompt-section {
  background: #fff8e1;
  border-radius: 16rpx;
  padding: 24rpx;
}

.prompt-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.prompt-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  white-space: pre-wrap;
}

.copy-btn {
  margin-top: 16rpx;
  height: 64rpx;
  background: #07c160;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 48rpx;
  height: 96rpx;
  background: #07c160;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
