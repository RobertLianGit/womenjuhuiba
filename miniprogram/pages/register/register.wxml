<!--pages/register/register.wxml-->
<view class="container">
  <!-- 方案内容 -->
  <view class="plan-section" wx:if="{{planContent}}">
    <text class="plan-title">活动方案</text>
    <text class="plan-content">{{planContent}}</text>
  </view>

  <!-- 分段选择 -->
  <view class="section" wx:if="{{scenes.length > 0}}">
    <text class="section-title">选择参加的段落</text>
    <view class="scene-list">
      <view class="scene-item" wx:for="{{scenes}}" wx:key="id" bindtap="toggleScene" data-id="{{item.id}}">
        <view class="scene-check {{item.selected ? 'checked' : ''}}">
          <image src="/assets/icon-check.png" wx:if="{{item.selected}}" style="width: 24rpx; height: 24rpx;" mode="aspectFit"></image>
        </view>
        <view class="scene-info">
          <view class="scene-name">{{item.name}}</view>
          <view class="scene-meta">
            <text wx:if="{{item.start_time}}">{{item.start_time}}</text>
            <text wx:if="{{item.location}}"> | {{item.location}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 报名信息 -->
  <view class="section">
    <text class="section-title">报名信息</text>
    <view class="form-row">
      <text class="form-label">人数</text>
      <input class="form-input" type="number" value="{{peopleCount}}" bindinput="onPeopleCountInput"/>
    </view>
    <view class="form-row">
      <text class="form-label">备注</text>
      <input class="form-input" placeholder="有什么想说的..." value="{{notes}}" bindinput="onNotesInput"/>
    </view>
  </view>

  <!-- 已报名列表 -->
  <view class="section" wx:if="{{registrations.length > 0}}">
    <text class="section-title">已报名 ({{totalPeople}}人)</text>
    <view class="registration-list">
      <view class="reg-item" wx:for="{{registrations}}" wx:key="id">
        <image class="reg-avatar" src="{{item.user_avatar || '/assets/default-avatar.png'}}" mode="aspectFill"></image>
        <text class="reg-name">{{item.user_name}}</text>
        <text class="reg-count">{{item.people_count}}人</text>
      </view>
    </view>
  </view>

  <button class="submit-btn" bindtap="submit">提交报名</button>
</view>
