/* pages/register/register.wxss */
.container {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

.plan-section {
  background: #e8f5e9;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.plan-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.plan-content {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.scene-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.scene-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.scene-check {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ccc;
  border-radius: 50%;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scene-check.checked {
  background: #07c160;
  border-color: #07c160;
}

.scene-info {
  flex: 1;
}

.scene-name {
  font-size: 30rpx;
  font-weight: 500;
}

.scene-meta {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.form-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #666;
}

.form-input {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.notes-input {
  width: 100%;
  min-height: 120rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.registration-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.reg-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.reg-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.reg-name {
  flex: 1;
  font-size: 28rpx;
}

.reg-count {
  font-size: 26rpx;
  color: #07c160;
}

.submit-btn {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 48rpx;
  height: 96rpx;
  background: #07c160;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
