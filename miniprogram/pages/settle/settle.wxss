/* pages/settle/settle.wxss */
.container {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

.summary-section {
  background: linear-gradient(135deg, #07c160, #06ad56);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  color: #fff;
}

.summary-title {
  font-size: 28rpx;
  opacity: 0.9;
}

.summary-amount {
  font-size: 56rpx;
  font-weight: 700;
  margin: 16rpx 0;
}

.summary-info {
  font-size: 26rpx;
  opacity: 0.8;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
}

.add-btn {
  font-size: 26rpx;
  color: #07c160;
  padding: 8rpx 16rpx;
  background: #e8f5e9;
  border-radius: 8rpx;
}

.bill-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bill-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.bill-info {
  flex: 1;
}

.bill-desc {
  font-size: 30rpx;
  font-weight: 500;
}

.bill-meta {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.bill-amount {
  font-size: 36rpx;
  font-weight: 700;
  color: #f44336;
}

.bill-actions {
  display: flex;
  gap: 16rpx;
  margin-left: 16rpx;
}

.bill-action {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.action-settle {
  background: #e8f5e9;
  color: #07c160;
}

.action-settled {
  background: #e0e0e0;
  color: #999;
}

.split-section {
  background: #e3f2fd;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.split-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.split-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 26rpx;
}

.split-name {
  color: #333;
}

.split-amount {
  font-weight: 600;
  color: #1976d2;
}

.form-input {
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.form-textarea {
  min-height: 100rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.form-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.form-row .form-input {
  flex: 1;
  margin-bottom: 0;
}

.admin-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.admin-input {
  display: flex;
  gap: 16rpx;
}

.admin-input input {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.verify-btn {
  width: 140rpx;
  height: 80rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-state {
  text-align: center;
  padding: 48rpx;
  color: #999;
  font-size: 28rpx;
}
