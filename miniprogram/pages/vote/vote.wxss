/* pages/vote/vote.wxss */
.container {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

.tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.tab {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border-radius: 12rpx;
  color: #666;
}

.tab.active {
  background: #07c160;
  color: #fff;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.proposal-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.proposal-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.proposal-item.selected {
  background: #e8f5e9;
  border-color: #07c160;
}

.proposal-check {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ccc;
  border-radius: 50%;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.proposal-check.checked {
  background: #07c160;
  border-color: #07c160;
}

.check-icon {
  width: 24rpx;
  height: 24rpx;
}

.proposal-content {
  flex: 1;
}

.proposal-name {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.proposal-desc {
  font-size: 26rpx;
  color: #666;
}

.proposal-votes {
  font-size: 26rpx;
  color: #07c160;
  margin-top: 8rpx;
}

.add-form {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.add-input {
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.add-textarea {
  min-height: 120rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.vote-rules {
  background: #fff8e1;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.rules-title {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.rules-text {
  font-size: 24rpx;
  color: #666;
}

.submit-btn {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 48rpx;
  height: 96rpx;
  background: #07c160;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
